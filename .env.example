# Flask
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000
SECRET_KEY=troque-este-valor-em-producao

# HBase (Thrift)
HBASE_HOST=localhost
HBASE_PORT=9090
HBASE_TABLE_PREFIX=iot

# Defina como 1 para usar o backend em memória (sem precisar de HBase/Docker).
# Útil para desenvolvimento e demonstração rápida.
USE_INMEMORY_DB=0

# OpenWeatherMap
# Crie uma chave gratuita em https://openweathermap.org/api
OPENWEATHER_API_KEY=coloque-sua-chave-aqui
OPENWEATHER_DEFAULT_CITY=Curitiba,BR

# ThingSpeak (opcional)
# Crie um channel em https://thingspeak.com e copie a Write API Key
THINGSPEAK_WRITE_KEY=
THINGSPEAK_CHANNEL_ID=
